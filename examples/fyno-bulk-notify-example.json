{
  "summary": "Notify multiple users with a single bulk event trigger",
  "description": "Fires a promotional_offer notification to a batch of users in one API call.",
  "request": {
    "method": "POST",
    "url": "https://api.fyno.io/v1/{WSID}/live/event/bulk",
    "headers": {
      "Authorization": "Bearer <API_KEY>",
      "Content-Type": "application/json"
    },
    "body": {
      "event": "promotional_offer",
      "batch": [
        {
          "distinct_id": "user-001",
          "data": {
            "offer_code": "SAVE20",
            "discount_percent": 20,
            "customer_name": "Alice"
          }
        },
        {
          "distinct_id": "user-002",
          "data": {
            "offer_code": "SAVE15",
            "discount_percent": 15,
            "customer_name": "Bob"
          }
        },
        {
          "to": {
            "email": "guest@example.com"
          },
          "data": {
            "offer_code": "SAVE10",
            "discount_percent": 10,
            "customer_name": "Guest"
          }
        }
      ]
    }
  },
  "response": {
    "status": 202,
    "body": {
      "requestId": "req_bulk_789",
      "message": "Bulk request accepted"
    }
  }
}
